# Copy to .env and fill in your API keys

# Azure OpenAI (used for GPT Image-2 generation + GPT-5.4 critique)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://your-resource.openai.azure.com/

# Anthropic via Databricks (used for Claude Opus evaluation + revision)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://your-workspace.databricks.com/

# Google Vertex AI (used for Gemini 3 Pro image generation + Gemini 3.1 Pro critique)
GOOGLE_API_KEY=AI...
